<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<TabPane xmlns:fx="http://javafx.com/fxml/1" styleClass="form" tabMinWidth="100" tabMaxWidth="200" tabClosingPolicy="UNAVAILABLE">
    <tabs>
        <Tab text="Sign In">
            <VBox alignment="CENTER" spacing="15" style="-fx-padding: 20;">
                <TextField promptText="Email" styleClass="input"/>
                <PasswordField promptText="Password" styleClass="input"/>
                <Button text="Login" styleClass="button"/>
            </VBox>
        </Tab>
        <Tab text="Sign Up">
            <VBox alignment="CENTER" spacing="15" style="-fx-padding: 20;">
                <TextField promptText="Email" styleClass="input"/>
                <TextField promptText="Username" styleClass="input"/>
                <PasswordField promptText="Password" styleClass="input"/>
                <Button text="Register" styleClass="button"/>
            </VBox>
        </Tab>
    </tabs>
</TabPane>
